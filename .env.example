# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# Anthropic (LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true   # set to false for mainnet

# Ethereum wallet (dedicated hot wallet only — minimal funds)
ETH_PRIVATE_KEY=0x...
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Solana wallet (dedicated hot wallet only — minimal SOL)
SOL_PRIVATE_KEY=
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# RPC providers
INFURA_API_KEY=
ALCHEMY_ETH_KEY=
ALCHEMY_SOL_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenClaw
OPENCLAW_SANDBOX=1
